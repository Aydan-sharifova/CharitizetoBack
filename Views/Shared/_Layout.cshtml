<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Charitize - Charity Organization</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@600;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/assets/css/style.css">
</head>
<body>
    <div class="loader" id="loader">
        <span></span>
    </div>

    <header class="site-header" id="top">
        <div class="topbar">
            <a class="brand" href="#top">Charitize</a>
            <div class="contact-strip">
                <div>
                    <i class="fa fa-phone"></i>
                    <span>Call Us</span>
                    <strong>+012 345 6789</strong>
                </div>
                <div>
                    <i class="fa fa-envelope-open"></i>
                    <span>Mail Us</span>
                    <strong>info@domain.com</strong>
                </div>
                <div>
                    <i class="fa fa-map-marker-alt"></i>
                    <span>Address</span>
                    <strong>123 Street, NY, USA</strong>
                </div>
            </div>
        </div>

        <nav class="navbar" id="navbar">
            <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <div class="nav-links" id="navLinks">
                <a href="#top" class="active">Home</a>
                <a href="#about">About</a>
                <a href="#services">Service</a>
                <a href="#donation">Donation</a>
                <a href="#events">Event</a>
                <a href="#team">Our Team</a>
                <a href="#contact">Contact</a>
            </div>
            <div class="social-links">
                <a href="#!" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a>
                <a href="#!" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                <a href="#!" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
            </div>
        </nav>
    </header>
            @RenderBody()
 <footer class="footer" id="contact">
        <div class="container footer-grid">
            <div>
                <h3>Our Office</h3>
                <p><i class="fa fa-map-marker-alt"></i> 123 Street, New York, USA</p>
                <p><i class="fa fa-phone"></i> +012 345 67890</p>
                <p><i class="fa fa-envelope"></i> info@example.com</p>
                <div class="footer-social"><a href="#!"><i class="fab fa-x-twitter"></i></a><a href="#!"><i class="fab fa-facebook-f"></i></a><a href="#!"><i class="fab fa-youtube"></i></a><a href="#!"><i class="fab fa-linkedin-in"></i></a></div>
            </div>
            <div>
                <h3>Quick Links</h3>
                <a href="#about">About Us</a>
                <a href="#contact">Contact Us</a>
                <a href="#services">Our Services</a>
                <a href="#!">Terms & Condition</a>
                <a href="#!">Support</a>
            </div>
            <div>
                <h3>Business Hours</h3>
                <p>Monday - Friday</p><strong>09:00 am - 07:00 pm</strong>
                <p>Saturday</p><strong>09:00 am - 12:00 pm</strong>
                <p>Sunday</p><strong>Closed</strong>
            </div>
            <div>
                <h3>Gallery</h3>
                <div class="gallery">
                    <img src="~/assets/img/gallery-1.jpg" alt="Gallery item 1">
                    <img src="~/assets/img/gallery-2.jpg" alt="Gallery item 2">
                    <img src="~/assets/img/gallery-3.jpg" alt="Gallery item 3">
                    <img src="~/assets/img/gallery-4.jpg" alt="Gallery item 4">
                    <img src="~/assets/img/gallery-5.jpg" alt="Gallery item 5">
                    <img src="~/assets/img/gallery-6.jpg" alt="Gallery item 6">
                </div>
            </div>
        </div>
        <div class="container copyright">
            <span>© Your Site Name, All Right Reserved.</span>
            <span>Designed By HTML Codex. Distributed by ThemeWagon.</span>
        </div>
    </footer>

    <div class="video-modal" id="videoModal" aria-hidden="true">
        <div class="video-dialog">
            <button id="closeVideo" aria-label="Close video"><i class="fa fa-xmark"></i></button>
            <iframe id="videoFrame" title="YouTube video" allow="autoplay; encrypted-media" allowfullscreen></iframe>
        </div>
    </div>

    <button class="back-to-top" id="backToTop" aria-label="Back to top"><i class="fa fa-arrow-up"></i></button>
    <script src="~/assets/js/main.js"></script>
</body>
</html>

